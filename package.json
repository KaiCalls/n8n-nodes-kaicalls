{
	"name": "n8n-nodes-kaicalls",
	"version": "0.1.0",
	"description": "n8n community node for KaiCalls, an AI voice agent platform. Trigger on new leads and completed calls, and create leads.",
	"keywords": [
		"n8n-community-node-package",
		"kaicalls",
		"voice",
		"ai",
		"leads",
		"calls"
	],
	"license": "MIT",
	"homepage": "https://www.kaicalls.com",
	"author": {
		"name": "KaiCalls",
		"email": "dev@kaicalls.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/KaiCalls/n8n-nodes-kaicalls.git"
	},
	"bugs": {
		"url": "https://github.com/KaiCalls/n8n-nodes-kaicalls/issues"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc --project tsconfig.json && node scripts/copy-assets.mjs",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/KaiCallsApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/KaiCallsLeadCreated/KaiCallsLeadCreated.node.js",
			"dist/nodes/KaiCallsCallCompleted/KaiCallsCallCompleted.node.js",
			"dist/nodes/KaiCallsLead/KaiCallsLead.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.37.1",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
